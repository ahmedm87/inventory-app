datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─── Existing models (unchanged) ───

model AppConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model SyncRun {
  id              String        @id @default(cuid())
  status          SyncRunStatus @default(RUNNING)
  source          String        @default("fulfillmen")
  triggeredBy     String        @default("cron")
  startedAt       DateTime      @default(now())
  completedAt     DateTime?
  totalProcessed  Int           @default(0)
  totalUpdated    Int           @default(0)
  totalSkipped    Int           @default(0)
  totalUnmatched  Int           @default(0)
  totalErrors     Int           @default(0)
  errorMessage    String?
  entries         SyncEntry[]

  @@index([status])
  @@index([startedAt])
}

enum SyncRunStatus {
  RUNNING
  COMPLETED
  FAILED
}

model SyncEntry {
  id              String          @id @default(cuid())
  syncRunId       String
  syncRun         SyncRun         @relation(fields: [syncRunId], references: [id])
  sku             String
  warehouseQty    Int
  shopifyPrevQty  Int?
  shopifyNewQty   Int?
  status          SyncEntryStatus
  warehouseSource String?
  message         String?
  createdAt       DateTime        @default(now())

  @@index([syncRunId])
  @@index([sku])
}

enum SyncEntryStatus {
  UPDATED
  SKIPPED
  UNMATCHED
  DUPLICATE
  ERROR
}

// ─── New models for multi-warehouse order management ───

enum WarehouseProvider {
  FULFILLMEN
  SHIPBOB
}

enum WarehouseRegion {
  US
  EU
  AU
  CN
}

model Warehouse {
  id                String            @id @default(cuid())
  name              String
  provider          WarehouseProvider
  region            WarehouseRegion
  shopifyLocationId String
  isActive          Boolean           @default(true)
  isFallback        Boolean           @default(false)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  stockLevels         StockLevel[]
  orders              Order[]
  fulfillmentRequests FulfillmentRequest[]

  @@unique([region])
}

model StockLevel {
  id           String    @id @default(cuid())
  warehouseId  String
  warehouse    Warehouse @relation(fields: [warehouseId], references: [id])
  sku          String
  quantity     Int       @default(0)
  lastSyncedAt DateTime  @default(now())

  @@unique([warehouseId, sku])
  @@index([sku])
}

enum OrderProcessingStatus {
  PENDING
  ASSIGNING
  ASSIGNED
  FULFILLMENT_SENT
  FULFILLED
  CANCELLED
  REASSIGNING
  REASSIGNMENT_FAILED
}

model Order {
  id                        String                @id @default(cuid())
  shopifyOrderId            String
  shopifyOrderNumber        String?
  processingStatus          OrderProcessingStatus @default(PENDING)
  assignedWarehouseId       String?
  assignedWarehouse         Warehouse?            @relation(fields: [assignedWarehouseId], references: [id])
  destinationCountryCode    String?
  customerEmail             String?
  totalLineItems            Int                   @default(0)
  assignmentReason          String?
  assignedAt                DateTime?
  fulfilledAt               DateTime?
  requiresManualIntervention Boolean              @default(false)
  manualInterventionReason  String?
  createdAt                 DateTime              @default(now())
  updatedAt                 DateTime              @updatedAt

  lineItems           OrderLineItem[]
  fulfillmentRequests FulfillmentRequest[]

  @@unique([shopifyOrderId])
  @@index([processingStatus])
}

model OrderLineItem {
  id              String @id @default(cuid())
  orderId         String
  order           Order  @relation(fields: [orderId], references: [id])
  sku             String
  quantity        Int
  productTitle    String @default("")
  shopifyLineItemId String?
  createdAt       DateTime @default(now())

  @@index([orderId])
}

enum FulfillmentRequestStatus {
  PENDING
  SENT
  ACKNOWLEDGED
  SHIPPED
  CANCELLED
  FAILED
}

model FulfillmentRequest {
  id                String                   @id @default(cuid())
  orderId           String
  order             Order                    @relation(fields: [orderId], references: [id])
  warehouseId       String
  warehouse         Warehouse                @relation(fields: [warehouseId], references: [id])
  externalRequestId String?
  status            FulfillmentRequestStatus @default(PENDING)
  sentAt            DateTime?
  cancelledAt       DateTime?
  errorMessage      String?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  trackingUpdates TrackingUpdate[]

  @@index([orderId])
  @@index([status])
}

model TrackingUpdate {
  id                   String             @id @default(cuid())
  fulfillmentRequestId String
  fulfillmentRequest   FulfillmentRequest @relation(fields: [fulfillmentRequestId], references: [id])
  trackingNumber       String
  carrier              String
  trackingUrl          String?
  shippedAt            DateTime?
  deliveredAt          DateTime?
  createdAt            DateTime           @default(now())

  @@index([fulfillmentRequestId])
}
